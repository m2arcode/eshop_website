---
// MARKET theme layout — classic e-commerce shop (WoodMart-inspired)
import Analytics from '../components/Analytics.astro';
import { categories } from '../data/products.js';
const { title='MARKET — Men\'s Clothing Store', description='Men\'s clothing store — heavyweight essentials and relaxed tailoring, shipped worldwide.' } = Astro.props;
const base='/market';
---
<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
<Analytics />
<style is:global>
  :root{ --head:"Poppins",sans-serif; --body:"Inter",system-ui,sans-serif;
         --red:#d8232a; --ink:#1f2530; --muted:#7a8190; --gray:#f3f4f6; --line:#e5e7eb; }
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:var(--body);color:var(--ink);background:#fff;-webkit-font-smoothing:antialiased}
  a{color:inherit;text-decoration:none}
  .head{font-family:var(--head)}
  .wrap{max-width:1240px;margin:0 auto;padding:0 22px}
  .up{text-transform:uppercase;letter-spacing:.04em}
  .grid{display:grid;gap:20px}
  @media(min-width:880px){.c4{grid-template-columns:repeat(4,1fr)}.c3{grid-template-columns:repeat(3,1fr)}}
  @media(max-width:879px){.c4,.c3{grid-template-columns:repeat(2,1fr)}}
  .pill{display:inline-flex;align-items:center;gap:8px;background:var(--red);color:#fff;font-family:var(--head);font-weight:600;font-size:13px;padding:13px 26px;border-radius:3px;border:0;cursor:pointer}
  .pill:hover{filter:brightness(1.08)}
  .swb{position:relative;display:flex;align-items:center;justify-content:center}
  .swb .tex{position:absolute;inset:0;opacity:.07;background-image:linear-gradient(#fff 1px,transparent 1px),linear-gradient(90deg,#fff 1px,transparent 1px);background-size:24px 24px}
  .card{border:1px solid var(--line);border-radius:8px;overflow:hidden;background:#fff;transition:.2s}
  .card:hover{box-shadow:0 10px 30px rgba(0,0,0,.08)}
</style>
</head>
<body>
<div style="background:var(--ink);color:#cfd4dd;font-size:12px">
  <div class="wrap" style="display:flex;justify-content:space-between;align-items:center;height:38px">
    <span>English ▾ &nbsp;|&nbsp; USD ▾</span>
    <span style="font-weight:600;color:#fff" class="uthide">FREE WORLDWIDE SHIPPING ON ORDERS OVER $150</span>
    <span style="display:flex;gap:14px"><a href={`${base}/about`}>About</a><a href={`${base}/contact`}>Contact</a></span>
  </div>
</div>
<header style="border-bottom:1px solid var(--line)">
  <div class="wrap" style="display:flex;align-items:center;gap:26px;padding:20px 22px">
    <a href={base} class="head" style="font-size:26px;font-weight:700">MAR<span style="color:var(--red)">KET</span></a>
    <div style="flex:1;max-width:600px;display:flex;border:2px solid var(--ink);border-radius:4px;overflow:hidden" class="srch">
      <input placeholder="Search for products…" style="flex:1;border:0;padding:11px 16px;font-size:14px;outline:none" />
      <button style="background:var(--ink);color:#fff;border:0;padding:0 18px;font-size:16px">🔍</button>
    </div>
    <div style="margin-left:auto;display:flex;gap:22px;align-items:center">
      <a href={`${base}/contact`} style="display:flex;flex-direction:column;align-items:center"><span style="font-size:18px">♡</span><span class="up" style="font-size:10px;color:var(--muted)">Wishlist</span></a>
      <a href={`${base}/contact`} style="display:flex;flex-direction:column;align-items:center"><span style="font-size:18px">🛒</span><span class="up" style="font-size:10px;color:var(--muted)">Cart</span></a>
    </div>
  </div>
</header>
<nav style="border-bottom:1px solid var(--line)">
  <div class="wrap" style="display:flex;gap:26px;align-items:center;height:48px;overflow-x:auto">
    {categories.map((c)=>(<a href={`${base}/shop/${c.id}`} class="head up" style="font-size:13px;font-weight:600;white-space:nowrap">{c.name}</a>))}
    <a href={`${base}/shop/tshirt`} class="head up" style="font-size:13px;font-weight:700;color:var(--red);white-space:nowrap">Sale</a>
  </div>
</nav>
<main>
  <slot />
</main>
<footer style="background:var(--ink);color:#aeb6c4;margin-top:40px">
  <div class="wrap" style="display:grid;gap:30px;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));padding:48px 22px">
    <div>
      <div class="head" style="font-size:22px;font-weight:700;color:#fff">MAR<span style="color:var(--red)">KET</span></div>
      <p style="margin-top:12px;font-size:13px;line-height:1.7;max-width:240px">Men's clothing store — heavyweight essentials and relaxed tailoring, shipped worldwide.</p>
    </div>
    <div><h4 class="head up" style="color:#fff;font-size:12px;margin-bottom:14px">Shop</h4>
      {categories.map((c)=>(<a href={`${base}/shop/${c.id}`} style="display:block;font-size:13px;margin-bottom:8px">{c.name}</a>))}
    </div>
    <div><h4 class="head up" style="color:#fff;font-size:12px;margin-bottom:14px">Help</h4>
      <a href={`${base}/contact`} style="display:block;font-size:13px;margin-bottom:8px">Contact</a>
      <a href={`${base}/about`} style="display:block;font-size:13px;margin-bottom:8px">About</a>
      <a href="/privacy" style="display:block;font-size:13px;margin-bottom:8px">Privacy policy</a>
    </div>
    <div><h4 class="head up" style="color:#fff;font-size:12px;margin-bottom:14px">Newsletter</h4>
      <p style="font-size:13px;margin-bottom:10px">Get 10% off your first order.</p>
      <div style="display:flex;border-radius:4px;overflow:hidden"><input placeholder="Email" style="flex:1;border:0;padding:10px;font-size:13px;outline:none" /><button style="background:var(--red);color:#fff;border:0;padding:0 14px;font-size:13px">Join</button></div>
    </div>
  </div>
  <div style="border-top:1px solid #2c3240"><div class="wrap" style="padding:16px 22px;font-size:12px;color:#7a8190">© 2026 MARKET. All rights reserved.</div></div>
</footer>
<style is:global>@media(max-width:700px){.uthide{display:none}.srch{display:none}}</style>
</body>
</html>
