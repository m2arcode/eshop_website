---
import { categories } from '../data/products.js';
const year = new Date().getFullYear();
---

<footer class="bg-ink text-paper mt-24">
  <div class="max-w-7xl mx-auto px-5 py-16 grid gap-10 md:grid-cols-4">
    <div class="md:col-span-2">
      <div class="font-display text-4xl font-black">VANTA</div>
      <p class="mt-4 max-w-sm text-paper/60 text-sm leading-relaxed">
        Men's streetwear built on heavyweight cotton and relaxed tailoring.
        Designed to be worn hard and kept for years.
      </p>
    </div>

    <div>
      <h4 class="font-display uppercase text-xs tracking-widest text-paper/50 mb-4">Shop</h4>
      <ul class="space-y-2 text-sm">
        {categories.map((c) => (
          <li><a href={`/shop/${c.id}`} class="text-paper/80 hover:text-acid transition-colors">{c.name}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h4 class="font-display uppercase text-xs tracking-widest text-paper/50 mb-4">Info</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="/about" class="text-paper/80 hover:text-acid transition-colors">About</a></li>
        <li><a href="/contact" class="text-paper/80 hover:text-acid transition-colors">Contact</a></li>
        <li><a href="/contact" class="text-paper/80 hover:text-acid transition-colors">Wholesale enquiry</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-paper/10">
    <div class="max-w-7xl mx-auto px-5 py-5 flex flex-col sm:flex-row gap-2 justify-between text-xs text-paper/40">
      <span>© {year} VANTA. All rights reserved.</span>
      <span>Built with Astro · Hosted on Cloudflare Pages</span>
    </div>
  </div>
</footer>
