---
import ProductImage from './ProductImage.astro';
const { product } = Astro.props;
---

<a href={`/product/${product.id}`} class="group block">
  <div class="overflow-hidden bg-white border border-ink/5">
    <div class="transition-transform duration-500 group-hover:scale-[1.03]">
      <ProductImage product={product} />
    </div>
  </div>
  <div class="mt-3 flex items-start justify-between gap-3">
    <div>
      <h3 class="font-display uppercase text-sm font-bold tracking-wide leading-tight">{product.name}</h3>
      <div class="mt-1 flex items-center gap-1.5">
        {product.colors.map((c) => (
          <span class="w-3 h-3 rounded-full border border-ink/20" style={`background-color:${c.hex}`} title={c.name}></span>
        ))}
      </div>
    </div>
    <span class="font-display text-sm font-bold whitespace-nowrap">${product.price}</span>
  </div>
</a>
