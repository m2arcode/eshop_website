---
const { product, base = '/store' } = Astro.props;
const kw = ({ tshirt:'tshirt,menswear', hoodie:'hoodie,sweatshirt', suit:'suit,man', shorts:'shorts,menswear' })[product.category] || 'menswear';
const lock = [...product.id].reduce((a, c) => a + c.charCodeAt(0), 0);
const img = product.image || `https://picsum.photos/seed/${product.id}/600/600`;
---
<div class="rounded-lg border border-gray-200 bg-white p-4 transition hover:shadow-lg">
  <a href={`${base}/product/${product.id}`} class="block">
    <div class="relative aspect-square w-full overflow-hidden rounded-lg bg-gray-100">
      <img src={img} alt={product.name} loading="lazy" class="h-full w-full object-cover transition duration-500 hover:scale-105" />
      {product.badge && (
        <span class="absolute left-3 top-3 rounded bg-neutral-900 px-2 py-1 text-[10px] font-semibold uppercase tracking-wide text-white">{product.badge}</span>
      )}
    </div>
  </a>
  <div class="pt-4">
    <a href={`${base}/product/${product.id}`} class="text-base font-semibold leading-tight text-gray-900 hover:underline">{product.name}</a>
    <div class="mt-1.5 flex items-center gap-1 text-sm text-amber-400">★★★★★ <span class="text-xs text-gray-400">(in stock)</span></div>
    <div class="mt-3 flex items-center justify-between gap-3">
      <p class="text-xl font-extrabold text-gray-900">${product.price}</p>
      <a href={`${base}/product/${product.id}`} class="rounded-lg bg-neutral-900 px-4 py-2 text-sm font-medium text-white transition hover:bg-neutral-700">View</a>
    </div>
  </div>
</div>
