---
// THEME B — "MARKET"  Classic e-commerce shop (WoodMart-inspired)
import { categories, products } from '../data/products.js';
const featured = products.slice(0, 8);
const catIcon = { tshirt:'👕', hoodie:'🧥', suit:'🤵', shorts:'🩳' };
function stars(){ return '★★★★★'; }
---
<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>MARKET — Men's Clothing Store</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
<style>
  :root{ --head:"Poppins",sans-serif; --body:"Inter",system-ui,sans-serif;
         --red:#d8232a; --ink:#1f2530; --muted:#7a8190; --gray:#f3f4f6; --line:#e5e7eb; }
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:var(--body);color:var(--ink);background:#fff;-webkit-font-smoothing:antialiased}
  a{color:inherit;text-decoration:none}
  .head{font-family:var(--head)}
  .wrap{max-width:1240px;margin:0 auto;padding:0 22px}
  .up{text-transform:uppercase;letter-spacing:.04em}
  .grid{display:grid;gap:20px}
  @media(min-width:880px){.c4{grid-template-columns:repeat(4,1fr)}}
  @media(max-width:879px){.c4{grid-template-columns:repeat(2,1fr)}}
  .pill{display:inline-flex;align-items:center;gap:8px;background:var(--red);color:#fff;font-family:var(--head);font-weight:600;font-size:13px;padding:13px 26px;border-radius:3px}
  .pill.dark{background:var(--ink)}
  .pill:hover{filter:brightness(1.08)}
</style>
</head>
<body>

<!-- utility bar -->
<div style="background:var(--ink);color:#cfd4dd;font-size:12px">
  <div class="wrap" style="display:flex;justify-content:space-between;align-items:center;height:38px">
    <span>English ▾ &nbsp;|&nbsp; USD ▾</span>
    <span style="font-weight:600;color:#fff">FREE WORLDWIDE SHIPPING ON ORDERS OVER $150</span>
    <span style="display:flex;gap:14px"><a href="#">Newsletter</a><a href="#">Contact us</a><a href="#">FAQ</a></span>
  </div>
</div>

<!-- main header -->
<header style="border-bottom:1px solid var(--line)">
  <div class="wrap" style="display:flex;align-items:center;gap:26px;padding:22px 22px">
    <a href="#" class="head" style="font-size:26px;font-weight:700;letter-spacing:.02em">MAR<span style="color:var(--red)">KET</span></a>
    <div style="flex:1;max-width:620px;display:flex;border:2px solid var(--ink);border-radius:4px;overflow:hidden">
      <input placeholder="Search for products…" style="flex:1;border:0;padding:12px 16px;font-size:14px;outline:none" />
      <button style="background:var(--ink);color:#fff;border:0;padding:0 20px;font-size:16px">🔍</button>
    </div>
    <div style="margin-left:auto;display:flex;gap:24px;align-items:center;font-size:13px">
      <a href="#" style="display:flex;flex-direction:column;align-items:center"><span style="font-size:18px">♡</span><span class="up" style="font-size:10px;color:var(--muted)">Wishlist</span></a>
      <a href="#" style="display:flex;flex-direction:column;align-items:center"><span style="font-size:18px">🛒</span><span class="up" style="font-size:10px;color:var(--muted)">Cart</span></a>
    </div>
  </div>
</header>

<!-- category nav -->
<nav style="border-bottom:1px solid var(--line);background:#fff">
  <div class="wrap" style="display:flex;gap:28px;align-items:center;height:50px;overflow-x:auto">
    {categories.map((c)=>(
      <a href="#" class="head up" style="font-size:13px;font-weight:600;white-space:nowrap">{c.name}</a>
    ))}
    <a href="#" class="head up" style="font-size:13px;font-weight:700;color:var(--red);white-space:nowrap">Sale</a>
    <a href="#" class="head up" style="font-size:13px;font-weight:600;white-space:nowrap;margin-left:auto;color:var(--muted)">Track order</a>
  </div>
</nav>

<!-- hero banner -->
<section class="wrap" style="padding:24px 22px">
  <div style="position:relative;border-radius:8px;overflow:hidden;background:linear-gradient(100deg,#1f2530,#39414f);min-height:360px;display:flex;align-items:center;padding:50px">
    <div style="position:absolute;inset:0;opacity:.08;background-image:linear-gradient(#fff 1px,transparent 1px),linear-gradient(90deg,#fff 1px,transparent 1px);background-size:30px 30px"></div>
    <div style="position:relative;color:#fff;max-width:520px">
      <span class="head up" style="display:inline-block;background:var(--red);font-size:12px;font-weight:600;padding:6px 12px;border-radius:3px">New Season</span>
      <h1 class="head" style="font-size:clamp(34px,5vw,56px);font-weight:700;line-height:1.05;margin-top:18px">Men's essentials,<br/>up to <span style="color:#ffd34d">40% off</span></h1>
      <p style="margin-top:16px;color:#cfd4dd;font-size:16px;max-width:420px">Heavyweight tees, oversized hoodies, relaxed suits and shorts. Shop the new drop now.</p>
      <div style="margin-top:26px;display:flex;gap:12px;flex-wrap:wrap">
        <a href="#" class="pill">Shop now</a>
        <a href="#" class="pill" style="background:#fff;color:var(--ink)">View lookbook</a>
      </div>
    </div>
  </div>
</section>

<!-- featured categories -->
<section class="wrap" style="padding:14px 22px 8px">
  <div class="grid c4">
    {categories.map((c)=>(
      <a href="#" style="display:flex;align-items:center;gap:14px;border:1px solid var(--line);border-radius:8px;padding:16px 18px;transition:.2s" onmouseover="this.style.borderColor='#d8232a'" onmouseout="this.style.borderColor='#e5e7eb'">
        <span style="font-size:30px">{catIcon[c.id]}</span>
        <span><span class="head" style="display:block;font-weight:600;font-size:15px">{c.name}</span><span style="font-size:12px;color:var(--muted)">Shop now →</span></span>
      </a>
    ))}
  </div>
</section>

<!-- product grid -->
<section class="wrap" style="padding:34px 22px 10px">
  <div style="display:flex;align-items:center;gap:14px;margin-bottom:22px">
    <h2 class="head" style="font-size:24px;font-weight:700">Best sellers</h2>
    <span style="flex:1;height:2px;background:var(--gray)"></span>
    <a href="#" class="head up" style="font-size:12px;color:var(--red);font-weight:600">View all</a>
  </div>
  <div class="grid c4">
    {featured.map((p)=>(
      <div style="border:1px solid var(--line);border-radius:8px;overflow:hidden;background:#fff;transition:.2s" onmouseover="this.style.boxShadow='0 10px 30px rgba(0,0,0,.08)'" onmouseout="this.style.boxShadow='none'">
        <div style={`position:relative;aspect-ratio:1;background:${p.swatch};display:flex;align-items:center;justify-content:center`}>
          <div style="position:absolute;inset:0;opacity:.07;background-image:linear-gradient(#fff 1px,transparent 1px),linear-gradient(90deg,#fff 1px,transparent 1px);background-size:24px 24px"></div>
          <span class="head up" style="color:#fff;font-size:13px;font-weight:600;text-align:center;padding:0 16px">{p.name}</span>
          {p.badge && <span class="head up" style="position:absolute;top:10px;left:10px;background:var(--red);color:#fff;font-size:10px;font-weight:600;padding:4px 8px;border-radius:3px">{p.badge}</span>}
        </div>
        <div style="padding:14px">
          <div style="color:#f5a623;font-size:12px;letter-spacing:2px">{stars()}</div>
          <h3 class="head" style="font-size:14px;font-weight:600;margin:6px 0 8px">{p.name}</h3>
          <div style="display:flex;align-items:center;justify-content:space-between">
            <span class="head" style="font-weight:700;font-size:16px;color:var(--ink)">${p.price}</span>
            <button class="head up" style="background:var(--ink);color:#fff;border:0;font-size:11px;font-weight:600;padding:8px 12px;border-radius:4px;cursor:pointer">Add</button>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- trust strip -->
<section style="background:var(--gray);margin-top:40px">
  <div class="wrap grid c4" style="padding:30px 22px;gap:18px">
    {[['🚚','Free shipping','On orders over $150'],['↩️','14-day returns','Easy exchanges'],['🔒','Secure checkout','Your data protected'],['💬','Support','Mon–Fri 9–6']].map((x)=>(
      <div style="display:flex;gap:12px;align-items:center">
        <span style="font-size:26px">{x[0]}</span>
        <span><span class="head" style="display:block;font-weight:600;font-size:14px">{x[1]}</span><span style="font-size:12px;color:var(--muted)">{x[2]}</span></span>
      </div>
    ))}
  </div>
</section>

<!-- footer -->
<footer style="background:var(--ink);color:#aeb6c4">
  <div class="wrap" style="display:grid;gap:30px;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));padding:50px 22px">
    <div>
      <div class="head" style="font-size:22px;font-weight:700;color:#fff">MAR<span style="color:var(--red)">KET</span></div>
      <p style="margin-top:12px;font-size:13px;line-height:1.7;max-width:240px">Men's clothing store — heavyweight essentials and relaxed tailoring, shipped worldwide.</p>
    </div>
    <div><h4 class="head up" style="color:#fff;font-size:12px;margin-bottom:14px">Shop</h4>
      {categories.map((c)=>(<a href="#" style="display:block;font-size:13px;margin-bottom:8px">{c.name}</a>))}
    </div>
    <div><h4 class="head up" style="color:#fff;font-size:12px;margin-bottom:14px">Help</h4>
      <a href="#" style="display:block;font-size:13px;margin-bottom:8px">Shipping</a>
      <a href="#" style="display:block;font-size:13px;margin-bottom:8px">Returns</a>
      <a href="#" style="display:block;font-size:13px;margin-bottom:8px">Size guide</a>
      <a href="#" style="display:block;font-size:13px;margin-bottom:8px">Contact</a>
    </div>
    <div><h4 class="head up" style="color:#fff;font-size:12px;margin-bottom:14px">Newsletter</h4>
      <p style="font-size:13px;margin-bottom:10px">Get 10% off your first order.</p>
      <div style="display:flex;border-radius:4px;overflow:hidden">
        <input placeholder="Email" style="flex:1;border:0;padding:10px;font-size:13px;outline:none" />
        <button style="background:var(--red);color:#fff;border:0;padding:0 14px;font-size:13px">Join</button>
      </div>
    </div>
  </div>
  <div style="border-top:1px solid #2c3240"><div class="wrap" style="padding:16px 22px;font-size:12px;color:#7a8190">© 2026 MARKET. All rights reserved.</div></div>
</footer>

</body>
</html>
