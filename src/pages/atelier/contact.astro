---
import Layout from '../../layouts/AtelierLayout.astro';
import { site } from '../../data/site.js';
const action = site.formspreeId==='your-form-id' ? `mailto:${site.email}` : `https://formspree.io/f/${site.formspreeId}`;
const method = site.formspreeId==='your-form-id' ? 'GET' : 'POST';
---
<Layout title="Contact — ATELIER" description="Get in touch with ATELIER.">
  <section class="wrap" style="max-width:920px;padding:50px 28px;display:grid;gap:48px;grid-template-columns:1fr 1fr" class="ct">
    <div>
      <p class="up" style="font-size:11px;color:var(--tan);margin-bottom:16px">Contact</p>
      <h1 class="serif" style="font-size:clamp(34px,4vw,52px);font-weight:500;line-height:1.05">Let's talk.</h1>
      <p style="margin-top:20px;color:#5b554c;line-height:1.8;max-width:340px">Questions on sizing, an order or a wholesale enquiry? Send a message and we'll reply within one business day.</p>
      <p class="up" style="font-size:10px;color:#90897d;margin-top:28px">Email</p>
      <a href={`mailto:${site.email}`} style="font-size:15px">{site.email}</a>
    </div>
    <form action={action} method={method} style="display:flex;flex-direction:column;gap:16px;background:#fff;border:1px solid var(--line);padding:28px">
      <input name="name" placeholder="Name" required style="border:1px solid var(--line);padding:12px;font-family:var(--sans);font-size:14px" />
      <input name="email" type="email" placeholder="Email" required style="border:1px solid var(--line);padding:12px;font-family:var(--sans);font-size:14px" />
      <textarea name="message" rows="5" placeholder="Message" required style="border:1px solid var(--line);padding:12px;font-family:var(--sans);font-size:14px"></textarea>
      <button class="btn btn-tan" style="border:0;cursor:pointer">Send message</button>
    </form>
  </section>
  <style>@media(max-width:759px){.ct{grid-template-columns:1fr !important}}</style>
</Layout>
