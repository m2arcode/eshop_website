---
import Layout from '../../../layouts/AtelierLayout.astro';
import { products, getCategory, getProductsByCategory } from '../../../data/products.js';
import { site, alibabaHref } from '../../../data/site.js';
export function getStaticPaths(){ return products.map((p)=>({params:{id:p.id},props:{product:p}})); }
const { product } = Astro.props;
const cat = getCategory(product.category);
const related = getProductsByCategory(product.category).filter((p)=>p.id!==product.id).slice(0,3);
const base='/atelier';
const alibaba = alibabaHref(base);
---
<Layout title={`${product.name} — ATELIER`} description={product.desc}>
  <section class="wrap" style="padding:30px 28px 60px">
    <p class="up" style="font-size:10px;color:#90897d;margin-bottom:24px"><a href={base}>Home</a> · <a href={`${base}/shop/${cat.id}`}>{cat.name}</a> · {product.name}</p>
    <div style="display:grid;gap:48px;grid-template-columns:1fr" class="pd">
      <div style="display:grid;gap:48px;grid-template-columns:1fr 1fr;align-items:start" class="pdgrid">
        <div class="swatchblock" style={`aspect-ratio:4/5;background:${product.swatch}`}>
          <div class="tex"></div>
          <span class="serif" style="color:var(--cream);font-size:30px;text-align:center;padding:0 24px">{product.name}</span>
        </div>
        <div>
          {product.badge && <span class="up" style="display:inline-block;font-size:9px;border:1px solid var(--tan);color:var(--tan);padding:5px 10px;margin-bottom:18px">{product.badge}</span>}
          <h1 class="serif" style="font-size:clamp(30px,4vw,46px);font-weight:500;line-height:1.05">{product.name}</h1>
          <div class="serif" style="font-size:24px;margin-top:14px">${product.price}</div>
          <p style="margin-top:22px;color:#5b554c;line-height:1.8;font-size:15px">{product.desc}</p>

          <p class="up" style="font-size:10px;color:#90897d;margin-top:30px;margin-bottom:10px">Colour</p>
          <div style="display:flex;gap:10px">
            {product.colors.map((c)=>(<span style="display:flex;align-items:center;gap:8px;border:1px solid var(--line);padding:8px 12px"><span style={`width:14px;height:14px;border-radius:50%;background:${c.hex};border:1px solid #0002`}></span><span class="up" style="font-size:10px">{c.name}</span></span>))}
          </div>

          <p class="up" style="font-size:10px;color:#90897d;margin-top:24px;margin-bottom:10px">Size</p>
          <div style="display:flex;gap:8px;flex-wrap:wrap">
            {product.sizes.map((s)=>(<span class="serif" style="min-width:44px;text-align:center;border:1px solid var(--line);padding:8px 12px;font-size:15px">{s}</span>))}
          </div>

          <div style="margin-top:32px;display:flex;flex-direction:column;gap:12px">
            <a href={alibaba} target={site.alibabaUrl?'_blank':null} rel={site.alibabaUrl?'noopener':null} class="btn btn-tan" style="text-align:center;background:#ff6a00;border-color:#ff6a00">Enquire on Alibaba</a>
            <a href={`${base}/contact`} class="btn" style="text-align:center">Send an enquiry</a>
          </div>
        </div>
      </div>
      {related.length>0 && (
        <div style="margin-top:30px">
          <h2 class="serif" style="font-size:28px;font-weight:500;margin-bottom:26px">More {cat.name}</h2>
          <div class="grid c3">
            {related.map((p)=>(
              <a href={`${base}/product/${p.id}`}>
                <div class="swatchblock" style={`aspect-ratio:4/5;background:${p.swatch}`}><div class="tex"></div><span class="serif" style="color:var(--cream);font-size:22px;text-align:center;padding:0 16px">{p.name}</span></div>
                <div style="display:flex;justify-content:space-between;margin-top:12px"><span class="serif" style="font-size:17px">{p.name}</span><span style="font-size:13px">${p.price}</span></div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
  <style>@media(max-width:759px){.pdgrid{grid-template-columns:1fr !important}}</style>
</Layout>
