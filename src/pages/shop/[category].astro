---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { categories, getProductsByCategory, getCategory } from '../../data/products.js';

export function getStaticPaths() {
  return categories.map((c) => ({ params: { category: c.id } }));
}

const { category } = Astro.params;
const cat = getCategory(category);
const items = getProductsByCategory(category);
---

<Layout title={`${cat.name} — VANTA`} description={cat.tagline}>
  <!-- category header -->
  <section class="bg-ink text-paper">
    <div class="max-w-7xl mx-auto px-5 py-16">
      <nav class="text-xs uppercase tracking-widest text-paper/40 mb-5">
        <a href="/" class="hover:text-acid">Home</a> / <span class="text-paper/70">{cat.name}</span>
      </nav>
      <h1 class="font-display uppercase font-black text-5xl md:text-6xl leading-none">{cat.name}</h1>
      <p class="mt-3 text-paper/60">{cat.tagline}</p>
    </div>
  </section>

  <!-- category nav pills -->
  <div class="border-b border-ink/10 sticky top-16 bg-paper/90 backdrop-blur z-30">
    <div class="max-w-7xl mx-auto px-5 py-3 flex gap-3 overflow-x-auto">
      {categories.map((c) => (
        <a href={`/shop/${c.id}`}
           class={`whitespace-nowrap font-display uppercase text-xs tracking-widest px-4 py-2 border transition-colors ${c.id === category ? 'bg-ink text-paper border-ink' : 'border-ink/20 hover:border-ink'}`}>
          {c.name}
        </a>
      ))}
    </div>
  </div>

  <!-- product grid -->
  <section class="max-w-7xl mx-auto px-5 py-12">
    <p class="text-xs uppercase tracking-widest text-ink/40 mb-6">{items.length} {items.length === 1 ? 'piece' : 'pieces'}</p>
    <div class="grid gap-6 grid-cols-2 lg:grid-cols-3">
      {items.map((p) => <ProductCard product={p} />)}
    </div>
  </section>
</Layout>
