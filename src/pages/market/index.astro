---
import Layout from '../../layouts/MarketLayout.astro';
import { categories, products } from '../../data/products.js';
const featured = products.slice(0,8);
const base='/market';
const catIcon={tshirt:'👕',hoodie:'🧥',suit:'🤵',shorts:'🩳'};
---
<Layout>
  <!-- hero -->
  <section class="wrap" style="padding:24px 22px">
    <div class="swb" style="border-radius:8px;overflow:hidden;background:linear-gradient(100deg,#1f2530,#39414f);min-height:340px;justify-content:flex-start;padding:50px">
      <div class="tex"></div>
      <div style="position:relative;color:#fff;max-width:520px">
        <span class="head up" style="display:inline-block;background:var(--red);font-size:12px;font-weight:600;padding:6px 12px;border-radius:3px">New Season</span>
        <h1 class="head" style="font-size:clamp(34px,5vw,56px);font-weight:700;line-height:1.05;margin-top:18px">Men's essentials,<br/>up to <span style="color:#ffd34d">40% off</span></h1>
        <p style="margin-top:16px;color:#cfd4dd;font-size:16px;max-width:420px">Heavyweight tees, oversized hoodies, relaxed suits and shorts. Shop the new drop now.</p>
        <div style="margin-top:26px;display:flex;gap:12px;flex-wrap:wrap">
          <a href={`${base}/shop/tshirt`} class="pill">Shop now</a>
          <a href={`${base}/about`} class="pill" style="background:#fff;color:var(--ink)">Our story</a>
        </div>
      </div>
    </div>
  </section>
  <!-- featured categories -->
  <section class="wrap" style="padding:14px 22px 8px">
    <div class="grid c4">
      {categories.map((c)=>(
        <a href={`${base}/shop/${c.id}`} style="display:flex;align-items:center;gap:14px;border:1px solid var(--line);border-radius:8px;padding:16px 18px">
          <span style="font-size:30px">{catIcon[c.id]}</span>
          <span><span class="head" style="display:block;font-weight:600;font-size:15px">{c.name}</span><span style="font-size:12px;color:var(--muted)">Shop now →</span></span>
        </a>
      ))}
    </div>
  </section>
  <!-- products -->
  <section class="wrap" style="padding:34px 22px 10px">
    <div style="display:flex;align-items:center;gap:14px;margin-bottom:22px">
      <h2 class="head" style="font-size:24px;font-weight:700">Best sellers</h2>
      <span style="flex:1;height:2px;background:var(--gray)"></span>
      <a href={`${base}/shop/tshirt`} class="head up" style="font-size:12px;color:var(--red);font-weight:600">View all</a>
    </div>
    <div class="grid c4">
      {featured.map((p)=>(
        <a href={`${base}/product/${p.id}`} class="card" style="display:block">
          <div class="swb" style={`aspect-ratio:1;background:${p.swatch}`}>
            <div class="tex"></div>
            <span class="head up" style="color:#fff;font-size:13px;font-weight:600;text-align:center;padding:0 16px">{p.name}</span>
            {p.badge && <span class="head up" style="position:absolute;top:10px;left:10px;background:var(--red);color:#fff;font-size:10px;font-weight:600;padding:4px 8px;border-radius:3px">{p.badge}</span>}
          </div>
          <div style="padding:14px">
            <div style="color:#f5a623;font-size:12px;letter-spacing:2px">★★★★★</div>
            <h3 class="head" style="font-size:14px;font-weight:600;margin:6px 0 8px">{p.name}</h3>
            <div style="display:flex;align-items:center;justify-content:space-between">
              <span class="head" style="font-weight:700;font-size:16px">${p.price}</span>
              <span class="head up" style="background:var(--ink);color:#fff;font-size:11px;font-weight:600;padding:8px 12px;border-radius:4px">View</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
  <!-- trust strip -->
  <section style="background:var(--gray);margin-top:40px">
    <div class="wrap grid c4" style="padding:30px 22px;gap:18px">
      {[['🚚','Free shipping','On orders over $150'],['↩️','14-day returns','Easy exchanges'],['🔒','Secure checkout','Your data protected'],['💬','Support','Mon–Fri 9–6']].map((x)=>(
        <div style="display:flex;gap:12px;align-items:center"><span style="font-size:26px">{x[0]}</span><span><span class="head" style="display:block;font-weight:600;font-size:14px">{x[1]}</span><span style="font-size:12px;color:var(--muted)">{x[2]}</span></span></div>
      ))}
    </div>
  </section>
</Layout>
