---
import Layout from '../../../layouts/MarketLayout.astro';
import { categories, getProductsByCategory, getCategory } from '../../../data/products.js';
export function getStaticPaths(){ return categories.map((c)=>({params:{category:c.id}})); }
const { category } = Astro.params;
const cat = getCategory(category);
const items = getProductsByCategory(category);
const base='/market';
---
<Layout title={`${cat.name} — MARKET`} description={cat.tagline}>
  <section style="background:var(--gray);border-bottom:1px solid var(--line)">
    <div class="wrap" style="padding:22px">
      <p class="up" style="font-size:11px;color:var(--muted)"><a href={base}>Home</a> / {cat.name}</p>
      <h1 class="head" style="font-size:30px;font-weight:700;margin-top:4px">{cat.name}</h1>
      <p style="color:var(--muted);font-size:14px">{cat.tagline} · {items.length} products</p>
    </div>
  </section>
  <section class="wrap" style="padding:28px 22px 10px">
    <div class="grid c4">
      {items.map((p)=>(
        <a href={`${base}/product/${p.id}`} class="card" style="display:block">
          <div class="swb" style={`aspect-ratio:1;background:${p.swatch}`}>
            <div class="tex"></div>
            <span class="head up" style="color:#fff;font-size:13px;font-weight:600;text-align:center;padding:0 16px">{p.name}</span>
            {p.badge && <span class="head up" style="position:absolute;top:10px;left:10px;background:var(--red);color:#fff;font-size:10px;font-weight:600;padding:4px 8px;border-radius:3px">{p.badge}</span>}
          </div>
          <div style="padding:14px">
            <div style="color:#f5a623;font-size:12px;letter-spacing:2px">★★★★★</div>
            <h3 class="head" style="font-size:14px;font-weight:600;margin:6px 0 8px">{p.name}</h3>
            <div style="display:flex;align-items:center;justify-content:space-between"><span class="head" style="font-weight:700;font-size:16px">${p.price}</span><span class="head up" style="background:var(--ink);color:#fff;font-size:11px;font-weight:600;padding:8px 12px;border-radius:4px">View</span></div>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
