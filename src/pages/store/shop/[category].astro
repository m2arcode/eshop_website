---
import Layout from '../../../layouts/StoreLayout.astro';
import StoreProductCard from '../../../components/StoreProductCard.astro';
import { categories, getProductsByCategory, getCategory } from '../../../data/products.js';
export function getStaticPaths(){ return categories.map((c)=>({params:{category:c.id}})); }
const { category } = Astro.params;
const cat = getCategory(category);
const items = getProductsByCategory(category);
const base = '/store';
---
<Layout title={`${cat.name} — Store`} description={cat.tagline}>
  <section class="bg-gray-50">
    <div class="mx-auto max-w-screen-xl px-4 py-8">
      <nav class="text-sm text-gray-500"><a href={base} class="hover:text-neutral-900">Home</a> / <span class="text-gray-900">{cat.name}</span></nav>
      <h1 class="mt-2 text-3xl font-extrabold text-gray-900">{cat.name}</h1>
      <p class="mt-1 text-gray-500">{cat.tagline} · {items.length} products</p>
    </div>
  </section>
  <section class="px-4 py-8">
    <div class="mx-auto max-w-screen-xl">
      <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
        {items.map((p) => <StoreProductCard product={p} base={base} />)}
      </div>
    </div>
  </section>
</Layout>
