---
import Layout from '../../../layouts/StoreLayout.astro';
import StoreProductCard from '../../../components/StoreProductCard.astro';
import { products, getCategory, getProductsByCategory } from '../../../data/products.js';
import { site, alibabaHref } from '../../../data/site.js';
export function getStaticPaths(){ return products.map((p)=>({params:{id:p.id},props:{product:p}})); }
const { product } = Astro.props;
const cat = getCategory(product.category);
const related = getProductsByCategory(product.category).filter((p)=>p.id!==product.id).slice(0,4);
const base = '/store';
const alibaba = alibabaHref(base);
const kw = ({ tshirt:'tshirt,menswear', hoodie:'hoodie,sweatshirt', suit:'suit,man', shorts:'shorts,menswear' })[product.category] || 'menswear';
const lock = [...product.id].reduce((a, c) => a + c.charCodeAt(0), 0);
const img = product.image || `https://loremflickr.com/800/800/${kw}?lock=${lock}`;
---
<Layout title={`${product.name} — Store`} description={product.desc}>
  <section class="px-4 py-8">
    <div class="mx-auto max-w-screen-xl">
      <nav class="mb-6 text-sm text-gray-500">
        <a href={base} class="hover:text-neutral-900">Home</a> /
        <a href={`${base}/shop/${cat.id}`} class="hover:text-neutral-900">{cat.name}</a> /
        <span class="text-gray-900">{product.name}</span>
      </nav>
      <div class="grid gap-8 lg:grid-cols-2">
        <!-- image -->
        <div class="relative aspect-square overflow-hidden rounded-2xl border border-gray-200 bg-gray-100">
          <img src={img} alt={product.name} class="h-full w-full object-cover" />
        </div>
        <!-- info -->
        <div>
          {product.badge && <span class="inline-block rounded bg-neutral-900 px-2.5 py-1 text-xs font-semibold uppercase tracking-wide text-white">{product.badge}</span>}
          <h1 class="mt-3 text-3xl font-extrabold text-gray-900">{product.name}</h1>
          <div class="mt-2 flex items-center gap-2 text-amber-400">★★★★★ <span class="text-sm text-gray-400">In stock</span></div>
          <p class="mt-4 text-3xl font-extrabold text-gray-900">${product.price}</p>
          <p class="mt-4 leading-relaxed text-gray-600">{product.desc}</p>

          <h3 class="mt-6 text-sm font-semibold text-gray-900">Colour</h3>
          <div class="mt-2 flex flex-wrap gap-2">
            {product.colors.map((c)=>(
              <span class="flex items-center gap-2 rounded-lg border border-gray-200 px-3 py-2 text-sm">
                <span class="h-4 w-4 rounded-full border border-black/10" style={`background:${c.hex}`}></span>{c.name}
              </span>
            ))}
          </div>

          <h3 class="mt-5 text-sm font-semibold text-gray-900">Size</h3>
          <div class="mt-2 flex flex-wrap gap-2">
            {product.sizes.map((s)=>(<span class="min-w-11 rounded-lg border border-gray-200 px-3 py-2 text-center text-sm font-medium hover:border-neutral-900">{s}</span>))}
          </div>

          <div class="mt-6 flex flex-wrap gap-3">
            <a href={alibaba} target={site.alibabaUrl?'_blank':null} rel={site.alibabaUrl?'noopener':null} class="rounded-lg bg-[#ff6a00] px-6 py-3 text-sm font-semibold text-white hover:bg-[#e85f00]">Enquire on Alibaba</a>
            <a href={`${base}/contact`} class="rounded-lg bg-neutral-900 px-6 py-3 text-sm font-semibold text-white hover:bg-neutral-700">Send an enquiry</a>
          </div>
          <div class="mt-6 space-y-1.5 border-t border-gray-200 pt-5 text-sm text-gray-500">
            <p>Free worldwide shipping over $150</p>
            <p>14-day easy exchange</p>
          </div>
        </div>
      </div>

      {related.length>0 && (
        <div class="mt-14">
          <h2 class="mb-6 text-xl font-bold text-gray-900 sm:text-2xl">More {cat.name}</h2>
          <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
            {related.map((p) => <StoreProductCard product={p} base={base} />)}
          </div>
        </div>
      )}
    </div>
  </section>
</Layout>
