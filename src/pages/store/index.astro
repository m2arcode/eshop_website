---
import Layout from '../../layouts/StoreLayout.astro';
import StoreProductCard from '../../components/StoreProductCard.astro';
import { categories, products } from '../../data/products.js';
const bestSellers = products.slice(0, 8);
const newArrivals = products.slice(4, 8);
const base = '/store';
const catSwatch = { tshirt:'#1f2937', hoodie:'#111827', suit:'#0f172a', shorts:'#1f2933' };
const catImg = {
  tshirt:'https://picsum.photos/seed/cat-tshirt/600/450',
  hoodie:'https://picsum.photos/seed/cat-hoodie/600/450',
  suit:'https://picsum.photos/seed/cat-suit/600/450',
  shorts:'https://picsum.photos/seed/cat-shorts/600/450',
};
const reviews = [
  ['“Heaviest, best-fitting tee I own. Washed it ten times, still perfect.”','James R.','T-Shirts'],
  ['“The suit drapes incredibly for the price. Wore it to a wedding, got asked where it\'s from all night.”','Daniel K.','Suits'],
  ['“Hoodie is unreal — proper weight, proper oversized. Ordering a second.”','Marcus T.','Hoodies'],
];
---
<Layout>
  <!-- HERO -->
  <section class="bg-gray-50 px-4 pt-8 pb-6 md:pt-12">
    <div class="mx-auto max-w-screen-xl overflow-hidden rounded-2xl bg-white">
      <div class="grid items-center md:grid-cols-2">
        <div class="p-8 md:p-14">
          <span class="inline-block rounded bg-neutral-900 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white">New season 2026</span>
          <h1 class="mt-4 text-4xl font-extrabold leading-tight tracking-tight text-gray-900 lg:text-5xl">Heavyweight men's essentials, up to 40% off.</h1>
          <p class="mt-4 max-w-md text-gray-500">Tees, hoodies, suits and shorts built to last. Shop the new drop and enjoy free worldwide shipping over $150.</p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href={`${base}/shop/tshirt`} class="rounded-lg bg-neutral-900 px-6 py-3 text-sm font-semibold text-white transition hover:bg-neutral-700">Shop the drop</a>
            <a href={`${base}/about`} class="rounded-lg border border-gray-200 bg-white px-6 py-3 text-sm font-semibold text-gray-900 transition hover:bg-gray-100">Our story</a>
          </div>
        </div>
        <div class="relative flex min-h-[300px] items-center justify-center overflow-hidden bg-gradient-to-br from-gray-800 to-gray-950 md:min-h-[460px]">
          <div class="absolute inset-0 opacity-[0.08]" style="background-image:linear-gradient(#fff 1px,transparent 1px),linear-gradient(90deg,#fff 1px,transparent 1px);background-size:30px 30px"></div>
          <span class="relative text-center text-2xl font-extrabold uppercase tracking-wide text-white/90">New<br/>Collection</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CATEGORIES -->
  <section class="px-4 py-10 md:py-14">
    <div class="mx-auto max-w-screen-xl">
      <div class="mb-6 flex items-center justify-between">
        <h2 class="text-xl font-bold text-gray-900 sm:text-2xl">Shop by category</h2>
        <a href={`${base}/shop/tshirt`} class="hidden rounded-lg border border-gray-200 bg-white px-5 py-2.5 text-sm font-medium text-gray-900 hover:bg-gray-100 sm:inline-block">See all</a>
      </div>
      <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
        {categories.map((c) => (
          <a href={`${base}/shop/${c.id}`} class="group relative flex aspect-[4/3] flex-col justify-end overflow-hidden rounded-lg p-5 text-white" style={`background-color:${catSwatch[c.id]}`}>
            <img src={catImg[c.id]} alt={c.name} loading="lazy" class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/20 to-transparent"></div>
            <div class="relative">
              <p class="text-lg font-bold">{c.name}</p>
              <p class="mt-1 text-xs text-gray-200">{c.tagline}</p>
              <span class="mt-3 inline-block text-xs font-semibold text-white/90 transition group-hover:translate-x-1">Shop now →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- AD CAROUSEL -->
  <section class="px-4 pb-10">
    <div class="mx-auto max-w-screen-xl">
      <div class="relative overflow-hidden rounded-2xl" id="adCarousel">
        <!-- Slides wrapper -->
        <div class="flex transition-transform duration-500 ease-in-out" id="adSlides">

          <!-- Slide 1 — T-Shirts -->
          <div class="relative min-w-full h-[340px] md:h-[480px] flex-shrink-0">
            <img src="https://images.unsplash.com/photo-1523381294911-8d3cead13475?w=1600&q=80" alt="Heavyweight Tees" class="absolute inset-0 w-full h-full object-cover object-top" loading="eager" />
            <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/30 to-transparent"></div>
            <div class="absolute inset-0 flex items-center px-10 md:px-20">
              <div class="text-white max-w-md">
                <span class="text-xs font-semibold uppercase tracking-widest text-gray-300">New Drop 2026</span>
                <h3 class="mt-2 text-3xl md:text-5xl font-extrabold leading-tight">Heavyweight<br/>Tees</h3>
                <p class="mt-3 text-sm text-gray-200">240+ GSM cotton. Boxy fit. Built to last.</p>
                <a href={`${base}/shop/tshirt`} class="mt-5 inline-block rounded-lg bg-white px-6 py-3 text-sm font-semibold text-gray-900 hover:bg-gray-100 transition">Shop T-Shirts →</a>
              </div>
            </div>
          </div>

          <!-- Slide 2 — Hoodies -->
          <div class="relative min-w-full h-[340px] md:h-[480px] flex-shrink-0">
            <img src="https://images.unsplash.com/photo-1556821840-3a63f15732ce?w=1600&q=80" alt="Oversized Hoodies" class="absolute inset-0 w-full h-full object-cover object-center" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/30 to-transparent"></div>
            <div class="absolute inset-0 flex items-center px-10 md:px-20">
              <div class="text-white max-w-md">
                <span class="text-xs font-semibold uppercase tracking-widest text-gray-300">Winter Warmers</span>
                <h3 class="mt-2 text-3xl md:text-5xl font-extrabold leading-tight">Oversized<br/>Hoodies</h3>
                <p class="mt-3 text-sm text-gray-200">Brushed fleece. Proper weight. Up to 40% off.</p>
                <a href={`${base}/shop/hoodie`} class="mt-5 inline-block rounded-lg bg-white px-6 py-3 text-sm font-semibold text-gray-900 hover:bg-gray-100 transition">Shop Hoodies →</a>
              </div>
            </div>
          </div>

          <!-- Slide 3 — Suits -->
          <div class="relative min-w-full h-[340px] md:h-[480px] flex-shrink-0">
            <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=1600&q=80" alt="Relaxed Suits" class="absolute inset-0 w-full h-full object-cover object-top" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/30 to-transparent"></div>
            <div class="absolute inset-0 flex items-center px-10 md:px-20">
              <div class="text-white max-w-md">
                <span class="text-xs font-semibold uppercase tracking-widest text-gray-300">Just Landed</span>
                <h3 class="mt-2 text-3xl md:text-5xl font-extrabold leading-tight">Relaxed<br/>Tailoring</h3>
                <p class="mt-3 text-sm text-gray-200">Unstructured suits with an unhurried edge.</p>
                <a href={`${base}/shop/suit`} class="mt-5 inline-block rounded-lg bg-white px-6 py-3 text-sm font-semibold text-gray-900 hover:bg-gray-100 transition">Shop Suits →</a>
              </div>
            </div>
          </div>

          <!-- Slide 4 — Shorts -->
          <div class="relative min-w-full h-[340px] md:h-[480px] flex-shrink-0">
            <img src="https://images.unsplash.com/photo-1591047139829-d91aecb6caea?w=1600&q=80" alt="Summer Shorts" class="absolute inset-0 w-full h-full object-cover object-center" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/30 to-transparent"></div>
            <div class="absolute inset-0 flex items-center px-10 md:px-20">
              <div class="text-white max-w-md">
                <span class="text-xs font-semibold uppercase tracking-widest text-gray-300">SS26 Collection</span>
                <h3 class="mt-2 text-3xl md:text-5xl font-extrabold leading-tight">Built for<br/>the Heat</h3>
                <p class="mt-3 text-sm text-gray-200">Cargo shorts and relaxed cuts for summer.</p>
                <a href={`${base}/shop/shorts`} class="mt-5 inline-block rounded-lg bg-white px-6 py-3 text-sm font-semibold text-gray-900 hover:bg-gray-100 transition">Shop Shorts →</a>
              </div>
            </div>
          </div>

        </div>

        <!-- Prev / Next arrows -->
        <button id="adPrev" aria-label="Previous" class="absolute left-4 top-1/2 -translate-y-1/2 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-black/40 text-white backdrop-blur-sm hover:bg-black/70 transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button id="adNext" aria-label="Next" class="absolute right-4 top-1/2 -translate-y-1/2 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-black/40 text-white backdrop-blur-sm hover:bg-black/70 transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>

        <!-- Dot indicators -->
        <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-10" id="adDots">
          {[0,1,2,3].map(i => (
            <button data-idx={i} class={`h-2 rounded-full transition-all duration-300 ${i===0 ? 'w-6 bg-white' : 'w-2 bg-white/50'}`} aria-label={`Slide ${i+1}`}></button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <script>
    const slides = document.getElementById('adSlides');
    const dots = document.querySelectorAll('#adDots button');
    const total = 4;
    let cur = 0;
    let timer: ReturnType<typeof setInterval>;

    function goTo(n: number) {
      cur = (n + total) % total;
      (slides as HTMLElement).style.transform = `translateX(-${cur * 100}%)`;
      dots.forEach((d, i) => {
        d.classList.toggle('w-6', i === cur);
        d.classList.toggle('bg-white', i === cur);
        d.classList.toggle('w-2', i !== cur);
        d.classList.toggle('bg-white/50', i !== cur);
      });
    }

    function startTimer() { timer = setInterval(() => goTo(cur + 1), 4500); }
    function resetTimer() { clearInterval(tim