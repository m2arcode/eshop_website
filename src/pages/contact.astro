---
import Layout from '../layouts/Layout.astro';

// =============================================================
//  CONTACT FORM — sends to email via Formspree (free tier).
//  SETUP (one time):
//   1. Go to https://formspree.io, sign up free, create a form.
//   2. Copy your form ID (looks like  xyzabcd ).
//   3. Replace FORMSPREE_ID below with it.
//  Until then the form falls back to opening the user's mail app.
// =============================================================
const FORMSPREE_ID = 'your-form-id';
const formAction = FORMSPREE_ID === 'your-form-id'
  ? 'mailto:modafocus@gmail.com'
  : `https://formspree.io/f/${FORMSPREE_ID}`;
const formMethod = FORMSPREE_ID === 'your-form-id' ? 'GET' : 'POST';
---

<Layout title="Contact — VANTA" description="Get in touch with VANTA for orders, sizing and wholesale enquiries.">
  <section class="max-w-5xl mx-auto px-5 py-16 grid gap-12 md:grid-cols-2">
    <!-- left -->
    <div>
      <p class="font-display uppercase tracking-[0.4em] text-xs mb-5" style="color:#9aa800">Contact</p>
      <h1 class="font-display uppercase font-black text-5xl leading-none">Let's<br />talk.</h1>
      <p class="mt-6 text-ink/70 leading-relaxed max-w-sm">
        Questions on sizing, an order, or a wholesale enquiry? Send a message and we'll get back
        to you within one business day.
      </p>

      <div class="mt-10 space-y-4 text-sm">
        <div>
          <div class="font-display uppercase text-xs tracking-widest text-ink/40">Email</div>
          <a href="mailto:modafocus@gmail.com" class="hover:text-ink/50">modafocus@gmail.com</a>
        </div>
        <div>
          <div class="font-display uppercase text-xs tracking-widest text-ink/40">Hours</div>
          <span>Mon–Fri · 9am–6pm</span>
        </div>
      </div>
    </div>

    <!-- right: form -->
    <form action={formAction} method={formMethod} class="space-y-5 bg-white border border-ink/10 p-6 md:p-8">
      <div>
        <label class="font-display uppercase text-xs tracking-widest text-ink/50">Name</label>
        <input name="name" type="text" required
               class="mt-2 w-full border border-ink/20 px-4 py-3 text-sm focus:outline-none focus:border-ink" />
      </div>
      <div>
        <label class="font-display uppercase text-xs tracking-widest text-ink/50">Email</label>
        <input name="email" type="email" required
               class="mt-2 w-full border border-ink/20 px-4 py-3 text-sm focus:outline-none focus:border-ink" />
      </div>
      <div>
        <label class="font-display uppercase text-xs tracking-widest text-ink/50">Subject</label>
        <select name="subject" class="mt-2 w-full border border-ink/20 px-4 py-3 text-sm bg-white focus:outline-none focus:border-ink">
          <option>Order / sizing question</option>
          <option>Wholesale enquiry</option>
          <option>Returns & exchanges</option>
          <option>Something else</option>
        </select>
      </div>
      <div>
        <label class="font-display uppercase text-xs tracking-widest text-ink/50">Message</label>
        <textarea name="message" rows="5" required
                  class="mt-2 w-full border border-ink/20 px-4 py-3 text-sm focus:outline-none focus:border-ink"></textarea>
      </div>
      <button type="submit"
              class="w-full font-display uppercase tracking-widest text-sm bg-ink text-paper px-8 py-4 hover:bg-ink/80 transition-colors">
        Send message
      </button>
    </form>
  </section>
</Layout>
