---
// THEME A — "ATELIER"  Premium minimal menswear boutique
import { categories, products } from '../data/products.js';
const featured = products.filter((p) => p.badge).slice(0, 3);
const catImg = { tshirt:'#2a2722', hoodie:'#26241f', suit:'#1b1a17', shorts:'#302d26' };
---
<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>ATELIER — Considered Menswear</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
<style>
  :root{ --serif:"Cormorant Garamond",Georgia,serif; --sans:"Inter",system-ui,sans-serif;
         --cream:#f6f3ee; --ink:#1c1a17; --tan:#8a7355; --line:#e1dad0; }
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:var(--sans);background:var(--cream);color:var(--ink);font-weight:300;-webkit-font-smoothing:antialiased}
  .serif{font-family:var(--serif)}
  .wrap{max-width:1180px;margin:0 auto;padding:0 28px}
  a{color:inherit;text-decoration:none}
  .up{text-transform:uppercase;letter-spacing:.22em}
  .btn{display:inline-block;font-size:11px;padding:15px 34px;border:1px solid var(--ink);transition:.25s}
  .btn:hover{background:var(--ink);color:var(--cream)}
  .btn-tan{background:var(--tan);border-color:var(--tan);color:#fff}
  .btn-tan:hover{background:#6f5c43;border-color:#6f5c43}
  .grid{display:grid;gap:26px}
  @media(min-width:760px){.c3{grid-template-columns:repeat(3,1fr)}.c4{grid-template-columns:repeat(4,1fr)}}
  @media(max-width:759px){.c3,.c4{grid-template-columns:repeat(2,1fr)}}
</style>
</head>
<body>

<!-- top bar -->
<div style="border-bottom:1px solid var(--line)">
  <div class="wrap" style="display:flex;justify-content:space-between;align-items:center;height:42px;font-size:10px" class="up">
    <span class="up" style="color:var(--tan)">Complimentary shipping over $150</span>
    <span class="up" style="font-size:10px;letter-spacing:.18em">Worldwide delivery</span>
  </div>
</div>

<!-- header -->
<header class="wrap" style="display:flex;align-items:center;justify-content:space-between;padding-top:28px;padding-bottom:28px">
  <nav class="up" style="font-size:11px;display:flex;gap:30px">
    <a href="#">Shop</a><a href="#">Collections</a>
  </nav>
  <a href="#" class="serif" style="font-size:30px;letter-spacing:.18em;font-weight:500">ATELIER</a>
  <nav class="up" style="font-size:11px;display:flex;gap:30px">
    <a href="#">About</a><a href="#">Contact</a>
  </nav>
</header>

<!-- hero -->
<section class="wrap" style="padding:30px 28px 70px">
  <div style="display:grid;gap:40px;align-items:center;grid-template-columns:1fr" >
    <div style="position:relative;aspect-ratio:16/8;background:linear-gradient(120deg,#23211d,#3b372f);overflow:hidden;display:flex;align-items:flex-end;padding:48px">
      <div style="position:absolute;inset:0;opacity:.08;background-image:radial-gradient(#fff 1px,transparent 1px);background-size:22px 22px"></div>
      <div style="position:relative;color:var(--cream);max-width:560px">
        <p class="up" style="font-size:11px;color:#d8c9b3;margin-bottom:18px">The Spring Collection</p>
        <h1 class="serif" style="font-size:clamp(40px,6vw,78px);line-height:1.02;font-weight:500">Quiet luxury,<br/>built to last.</h1>
        <p style="margin-top:22px;max-width:400px;color:#d8d2c8;font-size:15px;line-height:1.7">Considered menswear in heavyweight cotton and unstructured tailoring — tees, hoodies, suits and shorts, made to be kept.</p>
        <div style="margin-top:30px;display:flex;gap:14px;flex-wrap:wrap">
          <a href="#" class="btn btn-tan up">Explore the edit</a>
          <a href="#" class="btn up" style="border-color:#d8c9b3;color:var(--cream)">Our story</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- collections -->
<section class="wrap" style="padding-bottom:70px">
  <div style="text-align:center;margin-bottom:40px">
    <p class="up" style="font-size:11px;color:var(--tan)">Browse</p>
    <h2 class="serif" style="font-size:40px;font-weight:500;margin-top:6px">The Collections</h2>
  </div>
  <div class="grid c4">
    {categories.map((c)=>(
      <a href="#" style="display:block">
        <div style={`aspect-ratio:3/4;background:${catImg[c.id]};position:relative;overflow:hidden;display:flex;align-items:flex-end;padding:22px`}>
          <div style="position:absolute;inset:0;opacity:.06;background-image:radial-gradient(#fff 1px,transparent 1px);background-size:18px 18px"></div>
          <span class="serif" style="position:relative;color:var(--cream);font-size:26px">{c.name}</span>
        </div>
        <p class="up" style="font-size:10px;color:#90897d;margin-top:12px">{c.tagline}</p>
      </a>
    ))}
  </div>
</section>

<!-- featured -->
<section style="background:#efe9e0;padding:70px 0">
  <div class="wrap">
    <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:40px">
      <h2 class="serif" style="font-size:36px;font-weight:500">Featured pieces</h2>
      <a href="#" class="up" style="font-size:11px;color:var(--tan)">View all</a>
    </div>
    <div class="grid c3">
      {featured.map((p)=>(
        <a href="#" style="display:block">
          <div style={`aspect-ratio:4/5;background:${p.swatch};position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center`}>
            <div style="position:absolute;inset:0;opacity:.06;background-image:radial-gradient(#fff 1px,transparent 1px);background-size:20px 20px"></div>
            <span class="serif" style="color:var(--cream);font-size:26px;text-align:center;padding:0 20px">{p.name}</span>
            <span class="up" style="position:absolute;top:16px;left:16px;font-size:9px;background:var(--cream);color:var(--ink);padding:5px 9px">{p.badge}</span>
          </div>
          <div style="display:flex;justify-content:space-between;margin-top:16px">
            <span class="serif" style="font-size:19px">{p.name}</span>
            <span style="font-size:14px">${p.price}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ethos -->
<section class="wrap" style="padding:80px 28px;text-align:center;max-width:760px">
  <p class="up" style="font-size:11px;color:var(--tan);margin-bottom:20px">Our ethos</p>
  <p class="serif" style="font-size:clamp(24px,3.5vw,34px);line-height:1.4;font-weight:400">“We make fewer things, better. Heavyweight fabric, an unhurried fit, and a finish that earns its place in your wardrobe for years.”</p>
</section>

<!-- footer -->
<footer style="border-top:1px solid var(--line);padding:50px 0">
  <div class="wrap" style="display:flex;flex-wrap:wrap;gap:24px;justify-content:space-between;align-items:center">
    <span class="serif" style="font-size:24px;letter-spacing:.16em">ATELIER</span>
    <nav class="up" style="font-size:11px;display:flex;gap:26px;flex-wrap:wrap">
      <a href="#">Shop</a><a href="#">About</a><a href="#">Contact</a><a href="#">Wholesale</a>
    </nav>
    <span class="up" style="font-size:10px;color:#90897d">© 2026 Atelier</span>
  </div>
</footer>

</body>
</html>
